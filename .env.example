# --- Development (recommended): dev server proxy → avoids browser CORS + OPTIONS preflight ---
# Copy to ".env.local" (gitignored). Restart `npm run dev` after changes.
#
# Backend base URL (ngrok, staging, etc.). Axios uses same-origin paths in dev;
# Quasar proxies these prefixes to API_PROXY_TARGET:
#   /client /catalogs /oauth /patients /assessment-templates /logout
# NPI Registry (browser cannot call CMS directly — CORS). Dev server proxies:
#   /npi-registry/* → https://npiregistry.cms.hhs.gov/*
API_PROXY_TARGET=https://your-api-host.example.com

# --- Optional: force axios to call the API URL from the browser ---
# Use when you are not using the proxy (cross-origin; browser will send OPTIONS).
# VITE_API_BASE_URL=https://your-api-host.example.com

# --- GitHub Pages (production static hosting) ---
# There is no .env on the server: the SPA is pre-built. Configure the API URL as
# a repository variable so CI injects it during `npm run build`:
#   GitHub → repo → Settings → Secrets and variables → Actions → Variables
#   Name:  VITE_API_BASE_URL
#   Value: https://your-public-api.example.com   (no trailing slash)
# The deploy workflow passes it to the build step (see .github/workflows/deploy.yml).
# CORS must allow your Pages origin (e.g. https://<user>.github.io) on the API.
